(hardened_security) {
    tls {
        curves x25519 secp256r1 secp384r1
        protocols tls1.3
    }

    header Strict-Transport-Security "max-age=63072000"
}

{
    email {$EMAIL}
    admin :2019
    metrics
}

import config/*.Caddyfile

www.grafana.{$URL} {
    import hardened_security
    redir https://grafana.{$URL}{uri} permanent
}

grafana.{$URL} {
    import hardened_security
    encode
    reverse_proxy http://platform_grafana:3000
}
